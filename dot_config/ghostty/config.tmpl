font-family = monospace

cursor-style = bar

theme = Kitty Default
background-opacity = 0.65

{{ $nu := lookPath "nu" -}}
{{ if $nu -}}
command = {{ $nu }}
env = SHELL={{ $nu }}
{{- end }}

notify-on-command-finish = always
notify-on-command-finish-action = bell

gtk-single-instance = true
quit-after-last-window-closed-delay = 1m
